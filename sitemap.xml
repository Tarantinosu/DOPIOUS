    document.head.appendChild(s);
  }
  function l1(){
    var s=document.createElement('script');
    s.src='https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js';
    s.onload=l2;document.head.appendChild(s);
  }
  document.readyState==='loading'?document.addEventListener('DOMContentLoaded',function(){setTimeout(l1,20);}):setTimeout(l1,20);
})();
</script>
